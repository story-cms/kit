import router from '@adonisjs/core/services/router';

const AudienceController = () => import('#controllers/audience_controller');

export default () => {
  router.get(':locale/audience/users', [AudienceController, 'users']);
  router.get(':locale/audience/export', [AudienceController, 'exportAudience']);
  router.get(':locale/audience', [AudienceController, 'index']);
};
