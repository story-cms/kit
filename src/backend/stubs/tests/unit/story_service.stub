{{{ 
  exports({ to: app.makePath('tests/unit/story_service.spec.ts') }) 
}}}
import { test } from '@japa/runner';
import testUtils from '@adonisjs/core/services/test_utils';
import type { HttpContext } from '@adonisjs/core/http';

import {
  ResourceFactory,
  StoryFactory,
  StoryLocalisation,
  StoryLocalisationFactory,
  StoryService,
  emptyTranslation,
  ChapterFactory,
  type PostedSection,
  type StorySection,
  type StoryVersion,
} from '@story-cms/kit';
import { createCustomCmsConfig, testCmsConfig } from '#tests/helpers/cms_mock';

const sourceLocale = testCmsConfig.languages[0].locale;
const translationLocale = testCmsConfig.languages[1].locale;

const uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

function createMockHttpContext(params: {
  storyId: number;
  locale: string;
}): HttpContext {
  return {
    params,
    auth: {
      use: () => ({
        user: {
          isAllowed: () => true,
        },
      }),
    },
  } as HttpContext;
}

function createGalleryHttpContext(locale: string): HttpContext {
  return {
    params: { locale },
    auth: {
      use: () => ({
        user: {
          isAllowed: () => true,
        },
      }),
    },
  } as HttpContext;
}

function versionFor(storyId: number, locale: string): StoryVersion {
  return { apiVersion: 1, locale, storyId };
}

test.group('Story service', (group) => {
  group.each.setup(() => testUtils.db().withGlobalTransaction());

  test('editProps hydrates attached resources and lists available resources', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').create();
    const localisation = story.localisations[0];

    const first = await ResourceFactory.merge({
      locale: localisation.locale,
      title: 'Alpha Resource',
    }).create();
    const second = await ResourceFactory.merge({
      locale: localisation.locale,
      title: 'Beta Resource',
    }).create();
    await ResourceFactory.merge({ locale: 'es', title: 'Spanish Resource' }).create();

    localisation.resources = [second.id, first.id];
    localisation.tags = 'gospel,john';
    await localisation.save();

    const service = new StoryService(testCmsConfig);
    const props = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: localisation.locale }),
    );

    assert.isDefined(props);
    assert.lengthOf(props!.availableResources, 2);
    assert.equal(props!.availableResources[0].title, 'Alpha Resource');
    assert.equal(props!.availableResources[1].title, 'Beta Resource');
    assert.lengthOf(props!.model.resources, 2);
    assert.equal(props!.model.resources[0].id, second.id);
    assert.equal(props!.model.resources[1].id, first.id);
    assert.equal(props!.model.tags, 'gospel,john');
    assert.isBoolean(props!.hasNoContent);
  });

  test('editProps returns undefined when story is missing', async ({ assert }) => {
    const service = new StoryService(testCmsConfig);
    const props = await service.editProps(
      createMockHttpContext({ storyId: 99999, locale: 'en' }),
    );

    assert.isUndefined(props);
  });

  test('editProps labels bespoke templates with (custom) suffix', async ({ assert }) => {
    const story = await StoryFactory.with('localisations').create();
    const config = createCustomCmsConfig({
      bespokeTemplates: [
        {
          id: 'course',
          name: 'Course',
          fields: [{ name: 'title', label: 'Title', widget: 'string' }],
        },
      ],
      storyTemplates: [
        {
          id: 'devotion',
          name: 'Devotion',
          fields: [{ name: 'title', label: 'Title', widget: 'string' }],
        },
      ],
    });
    const service = new StoryService(config);
    const props = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: sourceLocale }),
    );

    assert.isDefined(props);
    assert.equal(props!.templates[0].id, 'course');
    assert.equal(props!.templates[0].name, 'Course (custom)');
    assert.equal(props!.templates[1].id, 'devotion');
    assert.equal(props!.templates[1].name, 'Devotion');
  });

  test('createProps returns props on the source locale', async ({ assert }) => {
    const config = createCustomCmsConfig({
      storyTemplates: [
        {
          id: 'course',
          name: 'Course',
          fields: [{ name: 'title', label: 'Title', widget: 'string' }],
        },
      ],
    });
    const service = new StoryService(config);
    const props = await service.createProps(createGalleryHttpContext(sourceLocale));

    assert.isDefined(props);
    assert.equal(props!.model.template, 'course');
    assert.equal(props!.model.chapterLimit, 10);
    assert.equal(props!.model.storyType, 'Story');
    assert.equal(props!.model.chapterType, 'Chapter');
  });

  test('createProps returns undefined on a translation locale', async ({ assert }) => {
    const config = createCustomCmsConfig({
      storyTemplates: [
        {
          id: 'course',
          name: 'Course',
          fields: [{ name: 'title', label: 'Title', widget: 'string' }],
        },
      ],
    });
    const service = new StoryService(config);
    const props = await service.createProps(createGalleryHttpContext(translationLocale));

    assert.isUndefined(props);
  });

  test('editProps does not prefill tags from source when translation tags are empty', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.tags = 'gospel,john';
    await sourceLocal.save();

    const service = new StoryService(testCmsConfig);
    const props = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: translationLocale }),
    );

    assert.isDefined(props);
    assert.equal(props!.model.tags, '');
    assert.equal(props!.source!.tags, 'gospel,john');
  });

  test('editProps does not overwrite existing translation tags', async ({ assert }) => {
    const story = await StoryFactory.with('localisations').create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.tags = 'gospel,john';
    await sourceLocal.save();

    await StoryLocalisationFactory.merge({
      storyId: story.id,
      locale: translationLocale,
      tags: 'evangelio,juan',
    }).create();

    const service = new StoryService(testCmsConfig);
    const props = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: translationLocale }),
    );

    assert.isDefined(props);
    assert.equal(props!.model.tags, 'evangelio,juan');
  });

  test('editProps prefills coverImage from source when translation coverImage is empty', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.coverImage = 'https://example.com/en-cover.jpg';
    await sourceLocal.save();

    const service = new StoryService(testCmsConfig);
    const props = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: translationLocale }),
    );

    assert.isDefined(props);
    assert.equal(props!.model.coverImage, 'https://example.com/en-cover.jpg');
    assert.equal(props!.source!.coverImage, 'https://example.com/en-cover.jpg');
  });

  test('editProps does not mutate emptyTranslation singleton', async ({ assert }) => {
    const story = await StoryFactory.with('localisations').create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.coverImage = 'https://example.com/story-cover.jpg';
    sourceLocal.tags = 'gospel,john';
    await sourceLocal.save();

    const service = new StoryService(testCmsConfig);
    await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: translationLocale }),
    );

    assert.equal(emptyTranslation.coverImage, '');
    assert.equal(emptyTranslation.tags, '');
  });

  test('galleryIndex does not leak cover image across stories without translation rows', async ({
    assert,
  }) => {
    const storyA = await StoryFactory.with('localisations').merge({ order: 1 }).create();
    const storyB = await StoryFactory.with('localisations').merge({ order: 2 }).create();

    const sourceA = await StoryLocalisation.query()
      .where('storyId', storyA.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceA.coverImage = 'https://example.com/cover-a.jpg';
    await sourceA.save();

    const sourceB = await StoryLocalisation.query()
      .where('storyId', storyB.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceB.coverImage = 'https://example.com/cover-b.jpg';
    await sourceB.save();

    const service = new StoryService(testCmsConfig);
    await service.editProps(
      createMockHttpContext({ storyId: storyA.id, locale: translationLocale }),
    );

    const stories = await service.galleryIndex(createGalleryHttpContext(translationLocale));
    const galleryA = stories.find((item) => item.id === storyA.id);
    const galleryB = stories.find((item) => item.id === storyB.id);

    assert.isDefined(galleryA);
    assert.isDefined(galleryB);
    assert.equal(galleryA!.coverImage, 'https://example.com/cover-a.jpg');
    assert.equal(galleryB!.coverImage, 'https://example.com/cover-b.jpg');
  });

  test('homeStories hydrates attached resources for each story', async ({ assert }) => {
    const story = await StoryFactory.with('localisations').create();
    const localisation = story.localisations[0];

    const first = await ResourceFactory.merge({
      locale: localisation.locale,
      title: 'First Resource',
    }).create();
    const second = await ResourceFactory.merge({
      locale: localisation.locale,
      title: 'Second Resource',
    }).create();

    localisation.resources = [second.id, first.id];
    await localisation.save();

    const service = new StoryService(testCmsConfig);
    const { stories } = await service.homeStories(localisation.locale);

    const result = stories.find((item) => item.id === story.id);
    assert.isDefined(result);
    assert.lengthOf(result!.resources, 2);
    assert.equal(result!.resources[0].id, second.id);
    assert.equal(result!.resources[1].id, first.id);
    assert.equal(result!.resources[0].title, 'Second Resource');
  });

  test('galleryIndex uses per-locale publish status', async ({ assert }) => {
    const story = await StoryFactory.with('localisations').merge({ isPublished: true }).create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.isPublished = true;
    await sourceLocal.save();

    await StoryLocalisationFactory.merge({
      storyId: story.id,
      locale: translationLocale,
      isPublished: false,
      title: 'Historia traducida',
    }).create();

    const service = new StoryService(testCmsConfig);
    const sourceGallery = await service.galleryIndex(createGalleryHttpContext(sourceLocale));
    const translationGallery = await service.galleryIndex(
      createGalleryHttpContext(translationLocale),
    );

    assert.isTrue(sourceGallery.find((item) => item.id === story.id)?.isPublished);
    assert.isFalse(translationGallery.find((item) => item.id === story.id)?.isPublished);
  });

  test('editProps and updatePayloadFor use localisation publish status', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').merge({ isPublished: true }).create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.isPublished = true;
    await sourceLocal.save();

    await StoryLocalisationFactory.merge({
      storyId: story.id,
      locale: translationLocale,
      isPublished: false,
      title: 'Historia traducida',
      coverImage: 'https://example.com/es-cover.jpg',
    }).create();

    const service = new StoryService(testCmsConfig);
    const sourceProps = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: sourceLocale }),
    );
    const translationProps = await service.editProps(
      createMockHttpContext({ storyId: story.id, locale: translationLocale }),
    );
    const translationPayload = await service.updatePayloadFor(story.id, translationLocale);

    assert.isTrue(sourceProps!.model.isPublished);
    assert.isFalse(translationProps!.model.isPublished);
    assert.isFalse(translationPayload!.isPublished);
  });

  test('blockingPublishMessages counts chapters for the requested locale', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations')
      .merge({ chapterLimit: 1, isPublished: false })
      .create();

    await ChapterFactory.merge({
      storyId: story.id,
      locale: translationLocale,
      number: 1,
      apiVersion: 1,
    }).create();

    const service = new StoryService(testCmsConfig);
    const sourceMessages = await service.blockingPublishMessages(
      sourceLocale,
      story,
      {
        title: 'Ready',
        coverImage: 'https://example.com/cover.jpg',
        storyType: 'Story',
        chapterType: 'Chapter',
        visibility: 'public',
      },
    );
    const translationMessages = await service.blockingPublishMessages(
      translationLocale,
      story,
      {
        title: 'Listo',
        coverImage: 'https://example.com/cover.jpg',
        storyType: 'Story',
        chapterType: 'Chapter',
        visibility: 'public',
      },
    );

    assert.isAbove(sourceMessages.length, 0);
    assert.lengthOf(translationMessages, 0);
  });

  test('homeStories excludes stories unpublished in the requested locale', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').merge({ isPublished: true }).create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.isPublished = true;
    await sourceLocal.save();

    await StoryLocalisationFactory.merge({
      storyId: story.id,
      locale: translationLocale,
      isPublished: false,
      title: 'Historia traducida',
    }).create();

    const service = new StoryService(testCmsConfig);
    const { stories: sourceStories } = await service.homeStories(sourceLocale);
    const { stories: translationStories } = await service.homeStories(translationLocale);

    assert.isDefined(sourceStories.find((item) => item.id === story.id));
    assert.isUndefined(translationStories.find((item) => item.id === story.id));
  });
});

test.group('StoryService.preppedSections', (group) => {
  group.each.setup(() => testUtils.db().wrapInGlobalTransaction());

  const service = new StoryService(testCmsConfig);

  test('returns an empty array when sections are omitted', async ({ assert }) => {
    const result = await service.preppedSections(versionFor(1, sourceLocale));

    assert.deepEqual(result, []);
  });

  test('returns an empty array when sections are an empty array on the source locale', async ({
    assert,
  }) => {
    const result = await service.preppedSections(versionFor(1, sourceLocale), []);

    assert.deepEqual(result, []);
  });

  test('normalises source-locale sections with stable ids and descriptions', async ({
    assert,
  }) => {
    const posted: PostedSection[] = [
      { id: 'existing-id', title: 'Part One', description: 'First part' },
      { id: '  ', title: 'Part Two' },
      { id: '', title: 'Part Three', description: undefined },
      { title: 'Part Four' },
    ];

    const result = await service.preppedSections(versionFor(1, sourceLocale), posted);

    assert.lengthOf(result, 4);
    assert.equal(result[0].id, 'existing-id');
    assert.equal(result[0].title, 'Part One');
    assert.equal(result[0].description, 'First part');
    assert.match(result[1].id, uuidPattern);
    assert.equal(result[1].title, 'Part Two');
    assert.equal(result[1].description, '');
    assert.match(result[2].id, uuidPattern);
    assert.equal(result[2].title, 'Part Three');
    assert.equal(result[2].description, '');
    assert.match(result[3].id, uuidPattern);
    assert.equal(result[3].title, 'Part Four');
    assert.equal(result[3].description, '');
  });

  // ---------------------------
  // translations
  // ---------------------------

  test('returns an empty array for a translation when the source localisation is missing', async ({
    assert,
  }) => {
    const story = await StoryFactory.merge({ id: 90 }).create();

    const result = await service.preppedSections(versionFor(story.id, translationLocale), [
      { id: 'ignored', title: 'Translated title' },
    ]);

    assert.deepEqual(result, []);
  });

  test('returns an empty array for a translation when the source has no sections', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').merge({ id: 91 }).create();
    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.sections = [];
    await sourceLocal.save();

    const result = await service.preppedSections(versionFor(story.id, translationLocale), [
      { id: 'ignored', title: 'Translated title' },
    ]);

    assert.deepEqual(result, []);
  });

  test('maps posted translation sections onto source section ids by index', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').merge({ id: 92 }).create();
    const sourceSections: StorySection[] = [
      { id: 'section-a', title: 'Intro', description: 'Source intro' },
      { id: 'section-b', title: 'Deep dive', description: 'Source body' },
    ];

    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.sections = sourceSections;
    await sourceLocal.save();

    const posted: StorySection[] = [
      { id: 'client-id-a', title: 'Introducción', description: 'ES intro' },
      { id: 'client-id-b', title: 'Profundizar', description: 'ES body' },
    ];

    const result = await service.preppedSections(
      versionFor(story.id, translationLocale),
      posted,
    );

    assert.deepEqual(result, [
      { id: 'section-a', title: 'Introducción', description: 'ES intro' },
      { id: 'section-b', title: 'Profundizar', description: 'ES body' },
    ]);
  });

  test('keeps every source section when a translation post omits trailing sections', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').merge({ id: 93 }).create();
    const sourceSections: StorySection[] = [
      { id: 'section-a', title: 'Intro', description: 'Source intro' },
      { id: 'section-b', title: 'Deep dive', description: 'Source body' },
    ];

    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.sections = sourceSections;
    await sourceLocal.save();

    const result = await service.preppedSections(versionFor(story.id, translationLocale), [
      { id: 'client-id-a', title: 'Solo intro', description: 'Solo ES' },
    ]);

    assert.deepEqual(result, [
      { id: 'section-a', title: 'Solo intro', description: 'Solo ES' },
      { id: 'section-b', title: '', description: '' },
    ]);
  });

  test('ignores extra posted sections beyond the source section count', async ({
    assert,
  }) => {
    const story = await StoryFactory.with('localisations').merge({ id: 94 }).create();

    const sourceLocal = await StoryLocalisation.query()
      .where('storyId', story.id)
      .where('locale', sourceLocale)
      .firstOrFail();
    sourceLocal.sections = [
      { id: 'section-a', title: 'Intro', description: 'Source intro' },
    ];
    await sourceLocal.save();

    const result = await service.preppedSections(versionFor(story.id, translationLocale), [
      { id: 'section-a', title: 'Introducción', description: 'ES intro' },
      { id: 'section-b', title: 'Extra', description: 'Should be dropped' },
    ]);

    assert.deepEqual(result, [
      { id: 'section-a', title: 'Introducción', description: 'ES intro' },
    ]);
  });
});
